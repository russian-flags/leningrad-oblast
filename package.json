{
  "name": "@russian-flags/leningrad-oblast",
  "version": "1.0.0",
  "description": "ES modules and lazy loaders for SVG flags of urban settlements in Leningrad Oblast.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lKolabrodl/leningrad-oblast-flags.git"
  },
  "bugs": {
    "url": "https://github.com/lKolabrodl/leningrad-oblast-flags/issues"
  },
  "homepage": "https://github.com/lKolabrodl/leningrad-oblast-flags#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "README.en.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./flags/*": {
      "types": "./dist/svg.d.ts",
      "default": "./dist/flags/*.svg"
    },
    "./flags/*.svg": {
      "types": "./dist/svg.d.ts",
      "default": "./dist/flags/*.svg"
    },
    "./svg/*": {
      "types": "./dist/svg.d.ts",
      "default": "./dist/flags/*.svg"
    },
    "./svg/*.svg": {
      "types": "./dist/svg.d.ts",
      "default": "./dist/flags/*.svg"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "node scripts/clean.js",
    "build:source": "node scripts/build-source.js",
    "build:js": "node scripts/build.js",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run clean && npm run build:source && npm run build:js && npm run build:types",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node __tests__/run.js && node tests/package-smoke.js",
    "pack:dry": "npm pack --dry-run",
    "prepack": "npm run build",
    "serve:demo": "node scripts/serve.js"
  },
  "keywords": [
    "leningrad-oblast",
    "russia",
    "flags",
    "svg",
    "esm",
    "lazy-loading"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "devDependencies": {
    "@types/node": "^24.0.3",
    "esbuild": "^0.25.11",
    "typescript": "^5.8.3"
  }
}
